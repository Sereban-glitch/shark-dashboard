# Shark Dashboard configuration
# Copy to .env and adjust if needed

# Server port (default: 8080)
SHARK_PORT=8080

# Refresh interval in seconds (default: 5)
SHARK_REFRESH=5

# Authentication token (optional, for protecting the dashboard)
# Generate with: openssl rand -hex 16
SHARK_TOKEN=

# Process manager to use: auto | systemd | pm2 | supervisord (default: auto)
SHARK_PM=auto
